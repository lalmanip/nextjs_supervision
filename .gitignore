# See https://help.github.com/articles/ignoring-files/

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
.next/
out/

# Production / misc build
build/
dist/

# Testing
coverage/
.nyc_output/

# Environment & secrets (never commit real keys)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
# Keep the template for others to copy:
!.env.example

# Vercel
.vercel

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# TypeScript
*.tsbuildinfo

# Turborepo / monorepo caches (if used later)
.turbo

# Optional local tooling (uncomment if you don’t want these in repo)
# .vscode/
# .idea/

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Certificates & keys
*.pem
*.key
*.p12

# IDEs / editors
*.swp
*.swo
*~
